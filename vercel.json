{
  "buildCommand": "cd lab-portal && npm install && npm run build",
  "outputDirectory": "lab-portal/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
