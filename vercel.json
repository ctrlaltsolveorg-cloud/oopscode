{
  "buildCommand": "cd lab-portal && npm install && npm run build",
  "outputDirectory": "lab-portal/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/c",
      "destination": "/index.html"
    },
    {
      "source": "/workspace",
      "destination": "/index.html"
    },
    {
      "source": "/revision",
      "destination": "/index.html"
    },
    {
      "source": "/notes",
      "destination": "/index.html"
    },
    {
      "source": "/admin",
      "destination": "/index.html"
    }
  ]
}
